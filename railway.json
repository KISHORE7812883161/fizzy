{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "echo 'Using pre-built dist folder'",
        "outputDir": "dist"
    },
    "deploy": {
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10,
        "startCommand": "npx serve dist -l $PORT",
        "healthcheckPath": "/",
        "healthcheckTimeout": 30
    }
}